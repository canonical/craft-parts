# -*- Mode:Python; indent-tabs-mode:nil; tab-width:4 -*-
import subprocess

import pytest
import pytest_subprocess
from craft_parts.errors import PluginEnvironmentValidationError
from craft_parts.infos import PartInfo, ProjectInfo
from craft_parts.parts import Part
from craft_parts.plugins.<plugin-key>_plugin import (
    <BuildSystem>Plugin,
    <BuildSystem>PluginProperties,
)
from craft_parts.plugins.validator import PluginEnvironmentValidator


@pytest.fixture
def part_info(new_dir):
    return PartInfo(
        project_info=ProjectInfo(application_name="test", cache_dir=new_dir),
        part=Part("my-part", {}),
    )


@pytest.fixture
def mock_validator(monkeypatch):
    def fake_execute(self, cmd: str):
        return subprocess.check_output(  # noqa: S602
            cmd,
            shell=True,
        )

    monkeypatch.setattr(PluginEnvironmentValidator, "_execute", fake_execute)


def test_property_validation():
    <BuildSystem>PluginProperties.validate_<prefix>_channel("stable")



def test_get_build_packages(part_info):
    properties = <BuildSystem>Plugin.properties_class.unmarshal({"source": "."})
    plugin = <BuildSystem>Plugin(properties=properties, part_info=part_info)
    assert plugin.get_build_packages() == {"git", "pkg-config"}


def test_get_pull_commands(part_info):
    properties = <BuildSystem>Plugin.properties_class.unmarshal(
        {"source": ".", "<prefix>-channel": "stable"}
    )
    plugin = <BuildSystem>Plugin(properties=properties, part_info=part_info)
    assert plugin.get_pull_commands() == ["<build-tool> toolchain install stable"]



def test_get_build_commands(part_info):
    properties = <BuildSystem>Plugin.properties_class.unmarshal(
        {
            "source": ".",
            "<prefix>-parameters": ["--locked"],
        }
    )
    plugin = <BuildSystem>Plugin(properties=properties, part_info=part_info)
    commands = plugin.get_build_commands()
    assert "<build-tool> build --release --locked" in commands[0]



def test_validate_environment_missing_tool(
    fake_process: pytest_subprocess.FakeProcess, mock_validator
):
    def exec_fail(x):
        raise subprocess.CalledProcessError(127, x)

    fake_process.register(["<build-tool-binary>", "--version"], callback=exec_fail)

    properties = <BuildSystem>Plugin.properties_class.unmarshal({"source": "."})
    validator = <BuildSystem>Plugin.validator_class(
        part_name="my-part", properties=properties, env=""
    )

    with pytest.raises(PluginEnvironmentValidationError):
        validator.validate_environment(part_dependencies=[])



def test_get_out_of_source_build(part_info):
    properties = <BuildSystem>Plugin.properties_class.unmarshal({"source": "."})
    plugin = <BuildSystem>Plugin(properties=properties, part_info=part_info)
    assert plugin.get_out_of_source_build() is False
